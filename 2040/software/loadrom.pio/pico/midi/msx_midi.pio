; MSX PICOVERSE PROJECT
; (c) 2026 Cristiano Goncalves
; The Retro Hacker
;
; msx_midi.pio - Dedicated PIO programs for the MSX USB MIDI cartridge
;
; Pin mapping:
;   GPIO  0-15  = A0..A15   (address bus, always input)
;   GPIO 16-23  = D0..D7    (data bus, bidirectional)
;   GPIO 24     = /RD       (active-low read strobe)
;   GPIO 25     = /WR       (active-low write strobe)
;   GPIO 26     = /IORQ     (active-low I/O request)
;   GPIO 27     = /SLTSL    (unused — MIDI uses I/O only)
;   GPIO 28     = /WAIT     (active-low, open-drain via PIO pindir)
;   GPIO 29     = BUSSDIR
;
; Intercepts MSX I/O cycles for MSX-MIDI interface emulation:
;   0xE8 (R/W) — MIDI data register (8251 USART)
;   0xE9 (R/W) — MIDI status/command register (8251)
;   0xEA-0xEF  — 8253 timer stubs
;
; This work is licensed under a "Creative Commons Attribution-NonCommercial-
; ShareAlike 4.0 International License".
; https://creativecommons.org/licenses/by-nc-sa/4.0/

; ===================================================================
; msx_midi_io_read — I/O read responder WITH /WAIT
; ===================================================================
; Intercepts I/O read cycles (/IORQ + /RD) and holds /WAIT while
; waiting for the CPU to supply the response byte.
;
; /WAIT is open-drain: the PIO output value is preloaded LOW.
;   set pindirs, 1 = /WAIT asserted   (Z80 frozen)
;   set pindirs, 0 = /WAIT released   (hi-Z, MSX pull-up restores high)
;
; in_base     = GPIO 0  (A0), 16 pins
; out_base    = GPIO 16 (D0), 8 pins
; set_base    = GPIO 28 (/WAIT)
; jmp_pin     = /RD (GPIO 24)
;
; TX FIFO data token from CPU (16 bits):
;   bits[7:0]  = data byte for D0..D7
;   bits[15:8] = pindirs (0xFF = drive bus, 0x00 = tri-state)

.program msx_midi_io_read

.wrap_target
wait_iorq:
    wait 0 gpio 26                ; Wait for /IORQ=0. /WAIT released.
    jmp pin wait_iorq             ; If /RD=1 (no read), loop back
    set pindirs, 1                ; Assert /WAIT=0 immediately to freeze Z80
    in pins, 16                   ; Capture A0..A15 into ISR
    push block                    ; Send address to CPU via RX FIFO
    pull block                    ; Stall until CPU responds (Z80 frozen)
    out pins, 8                   ; Drive D0..D7 with response byte
    out pindirs, 8                ; Set pindirs (0xFF = output)
    set pindirs, 0         [1]    ; Release /WAIT as hi-Z; data valid.
    wait 1 gpio 24                ; Wait for /RD=1 (bus cycle complete)
    set x, 0                      ; Prepare zero
    mov osr, x                    ; Load zero into OSR
    out pindirs, 8                ; Tri-state D0..D7
.wrap

; ===================================================================
; msx_midi_io_write — I/O write captor
; ===================================================================
; Captures address + data during I/O write cycles (/IORQ + /WR).
; Used for MIDI data writes ($E8) and command writes ($E9).
;
; No side-set needed (writes don't require bus hold).
; FIFO join RX for 8-deep buffering.
;
; RX FIFO word format (via mov isr, pins — 32 bits of GPIO state):
;   bits[7:0]   = A0..A7   (port address)
;   bits[15:8]  = A8..A15  (upper address, ignored)
;   bits[23:16] = D0..D7   (data byte)
;
; jmp_pin = /WR (GPIO 25)

.program msx_midi_io_write

.wrap_target
wait_iorq:
    wait 0 gpio 26           ; Wait for /IORQ=0
    jmp pin wait_iorq         ; If /WR=1, loop back
    nop              [2]     ; Let address + data settle (3 cycles)
    mov isr, pins            ; Snapshot all GPIOs into ISR
    push block               ; Send (addr+data) to CPU via RX FIFO
    wait 1 gpio 25           ; Wait for /WR=1 (cycle complete)
.wrap
